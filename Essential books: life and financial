<script>
(function(){
  "use strict";
  try{ document.documentElement.classList.add('js'); }catch(e){}

  var KEY='books35_v1';
  function load(){ try{ return JSON.parse(localStorage.getItem(KEY))||{}; }catch(e){ return {}; } }
  function save(p){ try{ localStorage.setItem(KEY, JSON.stringify(p)); }catch(e){} }
  var prog=load();

  var checks=[].slice.call(document.querySelectorAll('.check'));
  checks.forEach(function(btn){
    var id=btn.getAttribute('data-id');
    if(prog[id]) setState(btn,true,true);
    btn.addEventListener('click',function(e){ e.preventDefault(); e.stopPropagation(); toggle(btn,id); });
    btn.addEventListener('keydown',function(e){ if(e.key===' '||e.key==='Enter'){ e.preventDefault(); toggle(btn,id); } });
  });

  function toggle(btn,id){
    var on=!btn.classList.contains('done');
    setState(btn,on,false);
    if(on) prog[id]=1; else delete prog[id];
    save(prog); updateBars();
  }
  function setState(btn,on){
    btn.classList.toggle('done',on);
    btn.setAttribute('aria-checked',on?'true':'false');
    var w=btn.closest('.cardw'); if(w) w.classList.toggle('read',on);
  }

  function updateBars(){
    var bars=[].slice.call(document.querySelectorAll('[data-prog]'));
    bars.forEach(function(bar){
      var cat=bar.getAttribute('data-prog');
      var scope = cat==='all' ? document : document.getElementById(cat);
      if(!scope) return;
      var cs=[].slice.call(scope.querySelectorAll('.check'));
      var done=cs.filter(function(c){return c.classList.contains('done');}).length;
      var total=cs.length;
      var pct= total? (done/total*100):0;
      var fill=bar.querySelector('.fill'); if(fill) fill.style.width=pct+'%';
      if(cat==='all'){ var ov=document.getElementById('ovDone'); if(ov) ov.textContent=done; }
      else {
        var sec=document.getElementById(cat);
        var b=sec && sec.querySelector('.ct-done'); if(b) b.textContent=done;
      }
    });
  }

  var tabs=[].slice.call(document.querySelectorAll('.tab'));
  var cats=[].slice.call(document.querySelectorAll('.cat'));
  tabs.forEach(function(t){
    t.addEventListener('click',function(){
      var id=t.getAttribute('data-cat');
      tabs.forEach(function(x){ x.classList.toggle('active', x===t); });
      cats.forEach(function(c){ c.classList.toggle('active', c.id===id); });
      window.scrollTo({top:0,behavior:'smooth'});
    });
  });

  var reset=document.getElementById('reset');
  if(reset) reset.addEventListener('click',function(){
    if(confirm('Clear all your checkmarks on this device?')){
      prog={}; save(prog);
      checks.forEach(function(b){ setState(b,false); });
      updateBars();
    }
  });

  updateBars();
})();
</script>
